---
/**
 * Sélecteur de quantité à paliers dégressifs + ajout au panier.
 *
 * Hiérarchie visuelle pensée pour la conversion :
 *  1. le total du palier est l'élément dominant (c'est ce que l'acheteur paie) ;
 *  2. l'économie est isolée dans une pastille verte, plus saillante qu'un
 *     simple texte ;
 *  3. le palier sélectionné se distingue par une bordure épaisse, un fond
 *     teinté ET une pastille cochée — trois signaux plutôt qu'un seul, pour
 *     rester lisible y compris en cas de daltonisme.
 *
 * Le palier 2 est présélectionné : c'est le levier de panier moyen de la
 * boutique de référence. Tous les prix viennent de tierPrices() — aucune
 * valeur recopiée à la main.
 *
 * Accessibilité : vrai groupe de boutons radio (role="radiogroup"), navigable
 * au clavier, plutôt que des <div> cliquables.
 */
import type { Product } from '../data/products';
import { tierPrices, fmtPrice } from '../lib/pricing';
import { SITE } from '../data/products';

interface Props {
  product: Product;
}
const { product } = Astro.props;
const tiers = tierPrices(product);
const defaut = tiers.find((t) => t.highlight) ?? tiers[0];
---

<div class="mb-6">
  <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-[#75592F]">
    Choisissez votre quantité
  </p>

  <div role="radiogroup" aria-label="Choisissez votre quantité" class="space-y-3">
    {tiers.map((t) => (
      <button
        type="button"
        role="radio"
        aria-checked={t.qty === defaut.qty ? 'true' : 'false'}
        data-palier={t.qty}
        class="group relative w-full rounded-2xl border-2 border-[#EDE8E0] bg-white px-5 py-4 text-left transition-all hover:border-[#C4B89A] aria-checked:border-[#166534] aria-checked:bg-[#F4F9F2] aria-checked:shadow-[0_2px_12px_rgba(22,101,52,0.12)]"
      >
        {t.highlight && (
          <span class="absolute -top-2.5 right-4 rounded-full bg-[#166534] px-3 py-0.5 text-[11px] font-bold uppercase tracking-wide text-white">
            Le plus populaire
          </span>
        )}

        <span class="flex items-center gap-4">
          <!-- Pastille de sélection : vide, puis cochée -->
          <span
            class="relative flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full border-2 border-[#C4B89A] transition-colors group-aria-checked:border-[#166534] group-aria-checked:bg-[#166534]"
            aria-hidden="true"
          >
            <svg class="h-3.5 w-3.5 text-white opacity-0 transition-opacity group-aria-checked:opacity-100" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 10.5l4 4 8-9" />
            </svg>
          </span>

          <span class="min-w-0 flex-1">
            <span class="block font-semibold text-[#1A1A16]">{t.label}</span>
            <span class="block text-sm text-[#57534e]">
              {t.discountPercent > 0 ? (
                <>
                  <s class="text-[#A89880]">{fmtPrice(product.priceCurrent)} €</s>{' '}
                  <strong class="font-semibold text-[#166534]">{fmtPrice(t.unitPrice)} €</strong> / unité
                </>
              ) : (
                <>{fmtPrice(t.unitPrice)} € / unité</>
              )}
            </span>
          </span>

          <span class="flex-shrink-0 text-right">
            <span class="block font-display text-2xl font-bold leading-none text-[#1A1A16]">
              {fmtPrice(t.total)} €
            </span>
            {t.saving > 0 && (
              <span class="mt-1.5 inline-block rounded-full bg-[#D4E4D0] px-2.5 py-0.5 text-xs font-bold text-[#166534]">
                Économisez {fmtPrice(t.saving)} €
              </span>
            )}
          </span>
        </span>
      </button>
    ))}
  </div>

  <button
    type="button"
    data-ajouter-panier={product.slug}
    class="mt-5 w-full rounded-full bg-[#166534] px-10 py-4 font-semibold text-white transition-colors hover:bg-[#0D4A25]"
  >
    Ajouter au panier
  </button>

  <p class="mt-3 text-center text-sm text-[#57534e]">
    Livraison en 2-5 jours — <strong class="text-[#1A1A16]">offerte dès {SITE.freeShippingThreshold} €</strong>
  </p>

  <!-- Sans JavaScript, le panier ne fonctionne pas : la commande par email
       reste accessible plutôt que de laisser un bouton inerte. -->
  <noscript>
    <p class="mt-4 rounded-2xl border border-[#D4C9B8] bg-[#FDFBF7] p-4 text-sm text-[#57534e]">
      Le panier nécessite JavaScript. Vous pouvez commander par email à
      <a href="mailto:commande@aimezlanature.fr" class="font-semibold text-[#166534] underline">commande@aimezlanature.fr</a>.
    </p>
  </noscript>
</div>
