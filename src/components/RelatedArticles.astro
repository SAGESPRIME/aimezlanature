---
/**
 * Bloc « À lire aussi » — maillage interne en fin d'article.
 *
 * Alimenté par les mêmes sources que le hub /blog (guides.ts + articles.ts) :
 * ajouter un contenu là-bas le fait apparaître ici automatiquement, sans
 * toucher aux pages.
 *
 * La sélection démarre juste après la page courante et boucle sur la liste,
 * pour que chaque page propose un trio différent plutôt que toujours les trois
 * premiers guides.
 */
import { articles } from '../data/articles';
import { guides } from '../data/guides';

interface Props {
  /** href de la page courante, pour l'exclure de la liste. */
  currentHref: string;
  title?: string;
  limit?: number;
}

const { currentHref, title = 'À lire aussi', limit = 3 } = Astro.props;

// « Achat » = la page catalogue : ce n'est pas un contenu de lecture, on la
// laisse aux blocs CTA qui suivent.
const pool = [...guides, ...articles].filter((item) => item.category !== 'Achat');

const current = pool.findIndex((item) => item.href === currentHref);
const ordered =
  current >= 0
    ? [...pool.slice(current + 1), ...pool.slice(0, current)]
    : pool;

const related = ordered.slice(0, limit);
---

{related.length > 0 && (
  <section class="py-14 px-4 bg-[#F5F0E8]" aria-labelledby="a-lire-aussi">
    <div class="max-w-5xl mx-auto">
      <h2 id="a-lire-aussi" class="font-display text-3xl text-[#1A1A16] mb-8">{title}</h2>
      <div class="grid md:grid-cols-3 gap-5">
        {related.map((item) => (
          <article class="rounded-2xl border border-[#EDE8E0] bg-white p-6">
            <p class="text-xs tracking-widest uppercase text-[#75592F] mb-3">{item.category}</p>
            <h3 class="font-display text-xl text-[#1A1A16] mb-3 leading-snug">
              <a href={item.href} class="hover:text-[#166534] transition-colors">{item.title}</a>
            </h3>
            <p class="text-[#57534e] text-sm leading-relaxed">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
