---
/**
 * Icônes SVG inline (trait 1.8, style Lucide) — remplacent les emojis
 * utilisés comme icônes (anti-pattern « site généré par IA », rendu
 * incohérent selon l'OS). Décoratives par défaut : aria-hidden.
 */
interface Props {
  name: 'truck' | 'refresh' | 'droplet' | 'leaf' | 'bulb' | 'shield';
  class?: string;
}
const { name, class: className = 'w-4 h-4' } = Astro.props;

const paths: Record<string, string> = {
  truck:
    'M5 18H3V6h11v12M14 9h4l3 4v5h-2M7.5 18a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm9 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Z',
  refresh:
    'M3 12a9 9 0 0 1 15.5-6.2L21 8M21 3v5h-5M21 12a9 9 0 0 1-15.5 6.2L3 16M3 21v-5h5',
  droplet: 'M12 3s6 6.3 6 10.5a6 6 0 0 1-12 0C6 9.3 12 3 12 3Z',
  leaf: 'M6 21c0-9 4-14 13-16 1 9-3 14-11 14M6 21c2-5 5-8 9-10',
  bulb: 'M9 18h6M10 21h4M12 3a6 6 0 0 0-3.5 10.9c.7.5 1 1.3 1 2.1h5c0-.8.3-1.6 1-2.1A6 6 0 0 0 12 3Z',
  shield: 'M12 3l7 3v5c0 4.5-3 8.5-7 10-4-1.5-7-5.5-7-10V6l7-3ZM9 12l2 2 4-4',
};
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
><path d={paths[name]} /></svg>
