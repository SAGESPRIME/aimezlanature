---
/**
 * Tiroir panier — s'ouvre dès l'ajout d'un produit, sans quitter la fiche.
 *
 * C'est le principal levier de conversion repris de la boutique de référence :
 * l'acheteur voit immédiatement sa remise, la relance vers le palier suivant,
 * et peut payer sans navigation intermédiaire.
 *
 * La coque est rendue ici (vide) et remplie par public/js/cart.js : la CSP
 * du site interdit le JavaScript en ligne. Le catalogue et les paliers sont
 * injectés en JSON non exécutable, pour que les prix affichés soient ceux du
 * serveur — le montant débité est de toute façon recalculé dans /api/checkout.
 *
 * Accessibilité : role="dialog" + aria-modal, fermeture par Échap et par clic
 * sur le fond, focus déplacé dans le tiroir à l'ouverture puis rendu au
 * bouton d'origine à la fermeture.
 */
import { products, SITE } from '../data/products';
import { TIERS } from '../lib/pricing';
import PaymentMethods from './PaymentMethods.astro';

const catalogue = {
  products: products
    .filter((p) => p.inStock)
    .map((p) => ({ slug: p.slug, shortName: p.shortName, priceCurrent: p.priceCurrent })),
  tiers: TIERS.map((t) => ({ qty: t.qty, discountPercent: t.discountPercent })),
  freeShippingThreshold: SITE.freeShippingThreshold,
  shippingFee: 4.9,
};
---

<script type="application/json" id="catalogue" set:html={JSON.stringify(catalogue)} />

<!-- Fond assombri -->
<div
  id="tiroir-fond"
  hidden
  class="fixed inset-0 z-[90] bg-[#0D2818]/60 backdrop-blur-sm"
></div>

<aside
  id="tiroir-panier"
  hidden
  role="dialog"
  aria-modal="true"
  aria-labelledby="tiroir-titre"
  class="fixed top-0 right-0 bottom-0 z-[95] flex w-full max-w-md flex-col border-l border-[#D4C9B8] bg-[#FDFBF7] shadow-2xl"
>
  <header class="flex items-center justify-between gap-4 border-b border-[#EDE8E0] px-6 py-5">
    <h2 id="tiroir-titre" class="font-display text-2xl text-[#1A1A16]">
      Panier <span id="tiroir-compteur" class="text-[#6E5330] text-lg"></span>
    </h2>
    <button
      type="button"
      id="tiroir-fermer"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-[#D4C9B8] text-[#57534e] hover:bg-[#F5F0E8] transition-colors"
      aria-label="Fermer le panier"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </header>

  <!-- Lignes du panier -->
  <ul id="tiroir-lignes" class="flex-1 overflow-y-auto list-none m-0 px-6 py-2"></ul>

  <p id="tiroir-vide" hidden class="flex-1 px-6 py-10 text-center text-[#57534e]">
    Votre panier est vide.
  </p>

  <!-- Relance vers le palier suivant -->
  <p
    id="tiroir-relance"
    hidden
    class="mx-6 mb-2 rounded-xl border border-[#D4E4D0] bg-[#F4F9F2] px-4 py-3 text-sm font-semibold text-[#166534]"
  ></p>

  <footer id="tiroir-resume" hidden class="border-t border-[#EDE8E0] px-6 py-5">
    <dl class="space-y-1.5 text-sm text-[#57534e]">
      <div class="flex justify-between"><dt>Sous-total</dt><dd id="tiroir-sous-total">—</dd></div>
      <div id="tiroir-ligne-remise" hidden class="flex justify-between text-[#166534] font-semibold">
        <dt id="tiroir-remise-label">Remise</dt><dd id="tiroir-remise">—</dd>
      </div>
      <div class="flex justify-between"><dt>Livraison</dt><dd id="tiroir-port">—</dd></div>
    </dl>
    <div class="mt-3 flex items-baseline justify-between border-t border-[#D4C9B8] pt-3">
      <span class="font-semibold text-[#1A1A16]">Total TTC</span>
      <span id="tiroir-total" class="font-display text-2xl font-bold text-[#166534]">—</span>
    </div>

    <button
      type="button"
      data-payer
      class="mt-4 w-full rounded-full bg-[#166534] px-6 py-4 font-semibold text-white transition-colors hover:bg-[#0D4A25] disabled:opacity-60"
    >
      Commander
    </button>
    <p data-paiement-erreur hidden role="alert" class="mt-3 text-sm text-[#B91C1C]"></p>

    <PaymentMethods class="mt-4" />

    <a href="/panier/" class="mt-3 block text-center text-sm font-semibold text-[#6E5330] underline">
      Voir le panier complet
    </a>
  </footer>
</aside>

<p id="panier-annonce" class="sr-only" role="status" aria-live="polite"></p>
