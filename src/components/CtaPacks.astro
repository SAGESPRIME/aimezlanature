---
// Bandeau de conversion compact — réutilisé en bas des guides et pages info.
import { products } from '../data/products';
const packs = products.filter((p) => p.inStock);
---

<section class="py-16 px-4 bg-[#0D2818] text-white" aria-labelledby="cta-packs-titre">
  <div class="max-w-5xl mx-auto text-center">
    <p class="text-xs tracking-[0.3em] uppercase text-[#A8C4A0] mb-3">Passer à l'action</p>
    <h2 id="cta-packs-titre" class="font-display text-3xl lg:text-4xl mb-3">Prêt à purifier votre eau ?</h2>
    <p class="text-[#B8CCB4] mb-10 max-w-xl mx-auto">
      Perles de Céramique EM® authentiques, fabriquées au Japon. Livraison offerte dès 50 €,
      garantie 30 jours, 2,5 % reversés à des puits d'eau potable.
    </p>
    <div class="grid sm:grid-cols-3 gap-4 max-w-3xl mx-auto">
      {packs.map((p) => (
        <a
          href={`/perles-ceramique-em/${p.slug}/`}
          class="bg-white/5 border border-white/15 rounded-2xl p-5 hover:bg-white/10 hover:border-[#A8C4A0] transition-colors text-left"
        >
          <p class="font-display text-lg mb-1">{p.shortName}</p>
          <p class="text-xs text-[#B8CCB4] mb-3">{p.usages[0]}</p>
          <p class="font-bold text-[#A8C4A0]">{p.priceCurrent.toFixed(2).replace('.', ',')} €</p>
        </a>
      ))}
    </div>
    <a href="/perles-ceramique-em/" class="inline-block mt-8 text-sm font-semibold text-[#A8C4A0] border-b border-[#A8C4A0] pb-0.5 hover:text-white hover:border-white transition-colors">
      Comparer tous les packs →
    </a>
  </div>
</section>
