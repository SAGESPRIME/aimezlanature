---
import '../styles/global.css';
import { SITE, getProduct } from '../data/products';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
  ogImage?: string;
}

const {
  title,
  description,
  canonical,
  jsonLd,
  noindex = false,
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).href;

// Normalise jsonLd en tableau pour le slot
const schemas = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];

// Schema BreadcrumbList pour toutes les pages.
// Libellés lisibles : sans cette map, Google recevrait les slugs capitalisés
// (« Perles Ceramique Em », « Cgv ») dans le fil d'Ariane des résultats.
const segmentLabels: Record<string, string> = {
  'perles-ceramique-em': 'Perles de Céramique EM',
  'comment-ca-marche': 'Comment ça marche',
  'utilisations': '16 utilisations',
  'perles-de-ceramique-avis': 'Avis & science',
  'purifier-eau-robinet-comparatif': 'Comparatif purification',
  'blog': 'Guides',
  'a-propos': 'À propos',
  'faq': 'FAQ',
  'cgv': 'CGV',
  'contact': 'Contact',
  'mentions-legales': 'Mentions légales',
  // Articles de blog
  'alternative-carafe-filtrante': 'Alternative carafe filtrante',
  'perles-de-ceramique-ou-charbon-binchotan': 'Perles ou binchotan',
  'perles-de-ceramique-em-authentiques': 'Perles EM authentiques',
  'gourde-filtrante': 'Gourde filtrante',
};

function segmentLabel(seg: string): string {
  return (
    segmentLabels[seg] ??
    getProduct(seg)?.shortName ??
    seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())
  );
}

const breadcrumbSegments = Astro.url.pathname
  .replace(/\/$/, '')
  .split('/')
  .filter(Boolean);

const breadcrumbItems = [
  { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url + '/' },
  ...breadcrumbSegments.map((seg, i) => ({
    '@type': 'ListItem',
    position: i + 2,
    name: segmentLabel(seg),
    item: SITE.url + '/' + breadcrumbSegments.slice(0, i + 1).join('/') + '/',
  })),
];

const breadcrumbSchema =
  breadcrumbItems.length > 1
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbItems,
      }
    : null;

const allSchemas = breadcrumbSchema ? [breadcrumbSchema, ...schemas] : schemas;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={new URL(ogImage, SITE.url).href} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, SITE.url).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Polices auto-hébergées (@fontsource, importées dans global.css) :
         supprime les requêtes render-blocking vers Google Fonts et le
         transfert d'IP vers Google (position CNIL/RGPD). -->

    <!-- JSON-LD Structured Data (SSR only) -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="bg-stone-50 text-stone-800 font-sans antialiased overflow-x-hidden">
    <a
      href="#contenu"
      class="sr-only focus:not-sr-only focus:absolute focus:z-[60] focus:top-2 focus:left-2 focus:bg-white focus:text-green-800 focus:px-4 focus:py-2 focus:rounded-lg focus:shadow"
    >
      Aller au contenu
    </a>

    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-stone-200">
      <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between" aria-label="Navigation principale">
        <a href="/" class="font-display text-xl font-bold text-green-800 hover:text-green-700 transition-colors">
          Aimez la Nature
        </a>
        <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-stone-600">
          <li><a href="/perles-ceramique-em/" class="hover:text-green-700 transition-colors">Nos Perles</a></li>
          <li><a href="/blog/" class="hover:text-green-700 transition-colors">Guides</a></li>
          <li><a href="/comment-ca-marche/" class="hover:text-green-700 transition-colors">Comment ça marche</a></li>
          <li><a href="/faq/" class="hover:text-green-700 transition-colors">FAQ</a></li>
          <li><a href="/a-propos/" class="hover:text-green-700 transition-colors">Notre mission</a></li>
        </ul>
        <div class="flex items-center gap-2">
          <a
            href="/perles-ceramique-em/"
            class="bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-green-800 transition-colors"
          >
            Commander
          </a>
          <button
            id="menu-toggle"
            type="button"
            class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-lg border border-stone-200 text-stone-700 hover:bg-stone-100 transition-colors"
            aria-expanded="false"
            aria-controls="menu-mobile"
            aria-label="Ouvrir le menu"
          >
            <svg class="w-5 h-5 menu-icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <path d="M4 7h16M4 12h16M4 17h16" />
            </svg>
            <svg class="w-5 h-5 menu-icon-close hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <path d="M6 6l12 12M18 6L6 18" />
            </svg>
          </button>
        </div>
      </nav>
      <!-- Panneau mobile, replié par défaut, déplié par le bouton (js/site.js).
           Sans JS, tous les liens restent accessibles via le footer. -->
      <ul id="menu-mobile" class="hidden md:hidden border-t border-stone-200 bg-white px-4 py-3 space-y-1 text-sm font-medium text-stone-700">
        <li><a href="/perles-ceramique-em/" class="block px-2 py-2.5 rounded-lg hover:bg-stone-100">Nos Perles</a></li>
        <li><a href="/blog/" class="block px-2 py-2.5 rounded-lg hover:bg-stone-100">Guides</a></li>
        <li><a href="/comment-ca-marche/" class="block px-2 py-2.5 rounded-lg hover:bg-stone-100">Comment ça marche</a></li>
        <li><a href="/utilisations/" class="block px-2 py-2.5 rounded-lg hover:bg-stone-100">16 utilisations</a></li>
        <li><a href="/faq/" class="block px-2 py-2.5 rounded-lg hover:bg-stone-100">FAQ</a></li>
        <li><a href="/a-propos/" class="block px-2 py-2.5 rounded-lg hover:bg-stone-100">Notre mission</a></li>
        <li><a href="/contact/" class="block px-2 py-2.5 rounded-lg hover:bg-stone-100">Contact</a></li>
      </ul>
    </header>

    <!-- Breadcrumb (visible only on inner pages) -->
    {breadcrumbItems.length > 1 && (
      <div class="max-w-6xl mx-auto px-4 py-3">
        <ol class="flex items-center gap-2 text-xs text-stone-500">
          {breadcrumbItems.map((item, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && <span aria-hidden="true">/</span>}
              {i < breadcrumbItems.length - 1 ? (
                <a href={item.item} class="hover:text-green-700 transition-colors">{item.name}</a>
              ) : (
                <span class="text-stone-700 font-medium">{item.name}</span>
              )}
            </li>
          ))}
        </ol>
      </div>
    )}

    <!-- Main content -->
    <main id="contenu">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-stone-800 text-stone-300 mt-20">
      <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <p class="font-display text-white font-bold text-lg mb-3">Aimez la Nature</p>
          <p class="text-sm leading-relaxed">
            Perles de Céramique EM® japonaises pour purifier l'eau du robinet naturellement.
            Zéro plastique, du produit au colis.
          </p>
        </div>
        <div>
          <p class="text-white font-semibold mb-3">Nos produits</p>
          <ul class="space-y-2 text-sm">
            <li><a href="/perles-ceramique-em/pack-55-perles/" class="hover:text-white transition-colors">Pack 55 Perles</a></li>
            <li><a href="/perles-ceramique-em/pack-100-perles/" class="hover:text-white transition-colors">Pack 100 Perles</a></li>
            <li><a href="/perles-ceramique-em/pack-gourde-ceramique-em/" class="hover:text-white transition-colors">Pack Gourde</a></li>
            <li><a href="/perles-ceramique-em/gourde-ecologique/" class="hover:text-white transition-colors">Gourde Écologique</a></li>
          </ul>
        </div>
        <div>
          <p class="text-white font-semibold mb-3">Informations</p>
          <ul class="space-y-2 text-sm">
            <li><a href="/blog/" class="hover:text-white transition-colors">Guides perles de céramique</a></li>
            <li><a href="/comment-ca-marche/" class="hover:text-white transition-colors">Comment ça marche</a></li>
            <li><a href="/utilisations/" class="hover:text-white transition-colors">16 utilisations des perles</a></li>
            <li><a href="/perles-de-ceramique-avis/" class="hover:text-white transition-colors">Avis & science : le vrai du faux</a></li>
            <li><a href="/purifier-eau-robinet-comparatif/" class="hover:text-white transition-colors">Comparatif : purifier l'eau du robinet</a></li>
            <li><a href="/faq/" class="hover:text-white transition-colors">FAQ</a></li>
            <li><a href="/a-propos/" class="hover:text-white transition-colors">Notre mission</a></li>
            <li><a href="/contact/" class="hover:text-white transition-colors">Contact</a></li>
            <li><a href="/mentions-legales/" class="hover:text-white transition-colors">Mentions légales</a></li>
            <li><a href="/cgv/" class="hover:text-white transition-colors">CGV</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-stone-700 py-4 text-center text-xs text-stone-400">
        © {new Date().getFullYear()} Aimez la Nature — Tous droits réservés
      </div>
    </footer>

    <!-- JS minimal, servi en fichier externe pour rester compatible avec la CSP
         (script-src 'self') : menu mobile + apparitions au défilement. -->
    <script src="/js/site.js" defer></script>
  </body>
</html>
