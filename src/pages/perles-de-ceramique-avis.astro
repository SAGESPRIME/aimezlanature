---
import BaseLayout from '../layouts/BaseLayout.astro';
import Faq from '../components/Faq.astro';
import CtaPacks from '../components/CtaPacks.astro';
import { SITE } from '../data/products';
import { buildArticleSchema, buildFaqSchema } from '../lib/seo';

const metaTitle = 'Perles de céramique : dangers, avis scientifique — le vrai du faux | Aimez la Nature';
const metaDescription =
  'Les perles de céramique sont-elles dangereuses ? Que dit la science, que dit l\'UFC-Que Choisir ? Notre réponse honnête et sourcée : ce qui est prouvé, ce qui ne l\'est pas.';

// Ce que les perles font / ne font pas — cohérent avec la FAQ produit et /comment-ca-marche/
const verites = [
  { affirmation: 'Sans danger pour la santé (argile cuite inerte)', statut: 'vrai' },
  { affirmation: 'Améliorent le goût et réduisent la sensation de chlore', statut: 'constaté' },
  { affirmation: 'Limitent les dépôts de tartre (bouilloire, carafe)', statut: 'constaté' },
  { affirmation: 'Éliminent bactéries, virus ou métaux lourds', statut: 'faux' },
  { affirmation: 'Rendent potable une eau qui ne l\'est pas', statut: 'faux' },
  { affirmation: '« Dynamisent » ou « restructurent » l\'eau', statut: 'non prouvé' },
];

const statutStyle: Record<string, string> = {
  vrai: 'bg-[#D4E4D0] text-[#166534]',
  constaté: 'bg-[#EDE4D3] text-[#8B6F47]',
  faux: 'bg-[#F2DEDE] text-[#9B3B3B]',
  'non prouvé': 'bg-[#EDE8E0] text-[#57534e]',
};

const faqItems = [
  {
    question: 'Les perles de céramique sont-elles dangereuses ?',
    answer:
      'Non. Les perles de céramique EM® sont fabriquées en argile naturelle cuite à haute température : un matériau inerte qui ne relargue aucune substance dans l\'eau. Seules précautions de bon sens : les tenir hors de portée des jeunes enfants (risque d\'ingestion, comme tout petit objet) et ne jamais les utiliser pour « rendre potable » une eau qui ne l\'est pas — ce n\'est pas leur rôle.',
  },
  {
    question: 'Quel est l\'avis scientifique sur les perles de céramique ?',
    answer:
      'La science est nuancée. Ce qui est documenté : la céramique poreuse peut adsorber une partie du chlore et servir de support de cristallisation qui limite les dépôts de tartre sur les parois. Ce qui n\'est pas prouvé : les concepts de « dynamisation » ou de « restructuration » de l\'eau, et toute action sur les bactéries, pesticides ou métaux lourds. Nous ne revendiquons que ce qui est constaté : goût, chlore ressenti, tartre.',
  },
  {
    question: 'Que dit l\'UFC-Que Choisir des perles de céramique ?',
    answer:
      'L\'UFC-Que Choisir est sceptique : l\'association rappelle qu\'aucune étude indépendante ne démontre une amélioration sanitaire de l\'eau, et que l\'eau du robinet en France est déjà potable et très contrôlée. Nous sommes d\'accord sur les deux points. Les perles ne sont pas un dispositif de potabilisation : c\'est un objet de confort (goût, chlore ressenti, tartre) et une alternative zéro déchet aux bouteilles et cartouches, pour un achat unique d\'une vingtaine d\'euros.',
  },
  {
    question: 'Les perles de céramique éliminent-elles les pesticides ou les métaux lourds ?',
    answer:
      'Non, et méfiez-vous des sites qui le prétendent. Pour les métaux lourds, nitrates ou pesticides, il faut un filtre à charbon actif de qualité ou un osmoseur. Notre comparatif des solutions de purification détaille quelle technologie répond à quel besoin.',
  },
  {
    question: 'Les perles de céramique valent-elles le coup ?',
    answer:
      'Si votre eau est potable mais que son goût de chlore vous dérange, que votre bouilloire s\'entartre ou que vous voulez arrêter les bouteilles plastique : oui, pour un achat unique d\'environ 15 à 30 € qui dure des années. Si votre objectif est de traiter une contamination (nitrates, plomb, bactéries) : non, choisissez une filtration adaptée.',
  },
];

const jsonLd = [
  buildArticleSchema({
    headline: 'Perles de céramique : dangers, avis scientifique — le vrai du faux',
    description: metaDescription,
    path: '/perles-de-ceramique-avis/',
    datePublished: '2026-07-20',
  }),
  buildFaqSchema(faqItems),
];
---

<BaseLayout title={metaTitle} description={metaDescription} jsonLd={jsonLd}>
  <!-- HERO -->
  <section class="bg-[#F5F0E8] px-4 pt-12 pb-14">
    <div class="max-w-3xl mx-auto">
      <p class="text-xs tracking-[0.3em] uppercase text-[#8B6F47] mb-4">Avis & science · Réponse honnête</p>
      <h1 class="font-display text-4xl lg:text-5xl text-[#1A1A16] leading-[1.1] mb-5">
        Perles de céramique : dangers, avis scientifique — le vrai du faux
      </h1>
      <p class="text-[#57534e] text-lg leading-relaxed">
        « Perles de céramique danger », « avis scientifique », « que dit l'UFC-Que Choisir » :
        vous êtes des centaines à poser ces questions chaque mois. Voici notre réponse —
        y compris quand elle ne nous arrange pas.
      </p>
    </div>
  </section>

  <!-- VERDICT EN 30 SECONDES -->
  <section class="py-14 px-4 bg-white" aria-labelledby="verdict-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="verdict-titre" class="font-display text-3xl text-[#1A1A16] mb-6">Le verdict en 30 secondes</h2>
      <div class="rounded-2xl border border-[#D4C9B8] overflow-hidden">
        <ul class="divide-y divide-[#EDE8E0]">
          {verites.map((v) => (
            <li class="flex items-center justify-between gap-4 px-5 py-3.5 bg-white">
              <span class="text-sm text-[#57534e]">{v.affirmation}</span>
              <span class={`flex-shrink-0 text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide ${statutStyle[v.statut]}`}>
                {v.statut}
              </span>
            </li>
          ))}
        </ul>
      </div>
      <p class="text-sm text-[#57534e] mt-4">
        « Constaté » = rapporté de façon consistante par nos {SITE.totalReviews} clients et cohérent avec les
        propriétés connues de la céramique poreuse, sans étude clinique indépendante à grande échelle.
      </p>
    </div>
  </section>

  <!-- DANGER -->
  <section class="py-14 px-4 bg-[#F5F0E8]" aria-labelledby="danger-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="danger-titre" class="font-display text-3xl text-[#1A1A16] mb-6">Les perles de céramique sont-elles dangereuses ?</h2>
      <p class="text-[#57534e] leading-relaxed mb-4">
        <strong class="text-[#1A1A16]">Non — et c'est le point qui fait le plus consensus.</strong>
        Une perle de céramique EM® est de l'argile naturelle enrichie en micro-organismes
        efficaces (EM®), puis cuite à haute température. La cuisson fige la matière : le résultat
        est un matériau <strong class="text-[#1A1A16]">inerte</strong>, comme un plat en terre cuite,
        qui ne libère ni particule, ni substance chimique dans votre eau.
      </p>
      <p class="text-[#57534e] leading-relaxed mb-4">
        Les micro-organismes utilisés lors de la fabrication (lactobacilles, levures — les mêmes
        familles que dans un yaourt ou du pain au levain) ne survivent pas à la cuisson sous forme
        active : il ne s'agit donc pas de « boire des bactéries ».
      </p>
      <div class="rounded-2xl bg-white border border-[#EDE8E0] p-6">
        <p class="font-semibold text-[#1A1A16] mb-3">Deux précautions de bon sens tout de même :</p>
        <ul class="space-y-2 text-sm text-[#57534e]">
          <li>• Tenir les perles hors de portée des jeunes enfants — comme tout objet de petite taille, elles présentent un risque d'ingestion.</li>
          <li>• Ne jamais les utiliser pour tenter de rendre potable une eau de puits, de pluie ou de rivière : ce n'est pas leur fonction, et aucun produit de ce type ne le permet.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SCIENCE -->
  <section class="py-14 px-4 bg-white" aria-labelledby="science-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="science-titre" class="font-display text-3xl text-[#1A1A16] mb-6">Que dit la science, exactement ?</h2>
      <p class="text-[#57534e] leading-relaxed mb-4">
        La technologie EM® (Effective Microorganisms) a été mise au point dans les années 1980 par
        le professeur Teruo Higa, à l'université des Ryūkyūs au Japon, d'abord pour l'agriculture.
        Son application à l'eau de boisson est plus récente — et les études indépendantes sur ce
        sujet précis sont rares. Voici comment nous lisons l'état des connaissances :
      </p>
      <div class="space-y-4 mb-6">
        <div class="rounded-2xl border border-[#D4E4D0] bg-[#F4F9F2] p-6">
          <p class="font-semibold text-[#166534] mb-2">Plausible et cohérent avec la chimie connue</p>
          <p class="text-sm text-[#57534e] leading-relaxed">
            La céramique cuite est un matériau <strong>poreux</strong> : sa surface peut adsorber une
            partie du chlore dissous (le même principe, en moins puissant, que le charbon actif) et
            servir de point d'accroche à la cristallisation du calcaire — le tartre se forme alors sur
            les perles plutôt que sur la résistance de la bouilloire. C'est cohérent avec ce que nos
            clients constatent : goût adouci, moins de dépôts.
          </p>
        </div>
        <div class="rounded-2xl border border-[#EDE8E0] bg-[#FDFBF7] p-6">
          <p class="font-semibold text-[#8B6F47] mb-2">Non démontré scientifiquement</p>
          <p class="text-sm text-[#57534e] leading-relaxed">
            Les notions de « dynamisation », « restructuration » ou « mémoire » de l'eau n'ont aucun
            fondement scientifique établi. De même, aucune étude sérieuse ne montre une action des
            perles sur les bactéries, les virus, les nitrates, les pesticides ou les métaux lourds.
            Nous ne le revendiquons nulle part — et nous vous invitons à fuir les sites qui le font.
          </p>
        </div>
      </div>
      <p class="text-[#57534e] leading-relaxed">
        En résumé : les perles jouent dans la catégorie <strong class="text-[#1A1A16]">confort et goût</strong>,
        pas dans la catégorie traitement sanitaire. Pour comprendre quelle technologie traite quoi,
        consultez notre <a href="/purifier-eau-robinet-comparatif/" class="text-[#166534] font-semibold hover:underline">comparatif perles, charbon, carafe, osmoseur</a>.
      </p>
    </div>
  </section>

  <!-- UFC QUE CHOISIR -->
  <section class="py-14 px-4 bg-[#F5F0E8]" aria-labelledby="ufc-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="ufc-titre" class="font-display text-3xl text-[#1A1A16] mb-6">L'avis de l'UFC-Que Choisir : on vous le donne sans le déformer</h2>
      <p class="text-[#57534e] leading-relaxed mb-4">
        L'UFC-Que Choisir, comme plusieurs médias de défense des consommateurs, est
        <strong class="text-[#1A1A16]">sceptique</strong> vis-à-vis des perles de céramique. Ses deux
        arguments principaux : aucune étude indépendante ne démontre une amélioration
        <em>sanitaire</em> de l'eau, et l'eau du robinet française est déjà l'un des aliments les
        plus contrôlés — elle est potable sans traitement supplémentaire.
      </p>
      <p class="text-[#57534e] leading-relaxed mb-4">
        <strong class="text-[#1A1A16]">Nous sommes d'accord sur les deux points.</strong> Si votre eau
        est saine (c'est le cas de la quasi-totalité des réseaux français), les perles ne la rendront
        pas « plus saine ». Ce qu'elles changent, c'est l'expérience : le goût de chlore qui pousse
        tant de foyers vers l'eau en bouteille, et le tartre qui abîme les appareils.
      </p>
      <p class="text-[#57534e] leading-relaxed">
        Notre position tient en une phrase : pour une vingtaine d'euros, un achat unique et zéro
        déchet, les perles sont une alternative honnête aux bouteilles plastique et aux cartouches
        jetables — à condition de savoir ce qu'elles font
        (<a href="/comment-ca-marche/" class="text-[#166534] font-semibold hover:underline">goût, chlore ressenti, tartre</a>)
        et ce qu'elles ne font pas (traitement sanitaire). C'est exactement ce que cette page essaie de clarifier.
      </p>
    </div>
  </section>

  <!-- AVIS CLIENTS -->
  <section class="py-14 px-4 bg-white" aria-labelledby="avis-clients-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="avis-clients-titre" class="font-display text-3xl text-[#1A1A16] mb-6">Perles de céramique et eau du robinet : l'avis de nos {SITE.totalReviews} clients</h2>
      <p class="text-[#57534e] leading-relaxed mb-6">
        Note moyenne : <strong class="text-[#1A1A16]">★ {SITE.globalRating.toString().replace('.', ',')}/5</strong> sur
        {SITE.totalReviews} avis vérifiés, collectés après achat. Ce qui revient le plus souvent :
      </p>
      <ul class="space-y-3 text-[#57534e] mb-6">
        <li class="flex gap-3"><span class="text-[#166534] font-bold flex-shrink-0">1.</span> Le goût de chlore s'estompe — beaucoup de clients disent avoir arrêté l'eau en bouteille.</li>
        <li class="flex gap-3"><span class="text-[#166534] font-bold flex-shrink-0">2.</span> Moins de tartre visible dans la bouilloire et sur les verres au lave-vaisselle.</li>
        <li class="flex gap-3"><span class="text-[#166534] font-bold flex-shrink-0">3.</span> La simplicité : rien à recharger, rien à racheter, une ébullition tous les 3-6 mois.</li>
      </ul>
      <p class="text-sm text-[#57534e] bg-[#F5F0E8] rounded-2xl px-5 py-4">
        En toute transparence : une minorité de clients ne perçoit pas de différence de goût.
        C'est généralement le cas quand l'eau locale est déjà peu chlorée. Si c'est le vôtre après
        30 jours d'essai, notre garantie s'applique : vous êtes remboursé.
      </p>
    </div>
  </section>

  <Faq items={faqItems} title="Vos questions sur la fiabilité des perles" eyebrow="Pour aller plus loin" />
  <CtaPacks />
</BaseLayout>
