---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Faq from '../components/Faq.astro';
import CtaPacks from '../components/CtaPacks.astro';
import AnswerBox from '../components/AnswerBox.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import PageDate from '../components/PageDate.astro';
import { buildFaqSchema } from '../lib/seo';
import { getProductImage, getProductImageAlt } from '../lib/productImages';
import { PERLES_PAR_LITRE, dosages as tousLesDosages } from '../data/dosages';

const PATH = '/comment-ca-marche/';
// Cette page porte un schema HowTo (pas Article) : la date n'a donc pas
// d'équivalent machine à refléter, elle sert uniquement au lecteur.
const datePublished = '2026-07-20';

// Le Pack 55 est le format de référence pour la carafe décrite dans les étapes.
const photoSlug = 'pack-55-perles';

const metaTitle = 'Combien de perles de céramique par litre d\'eau ? | Aimez la Nature';
const metaDescription =
  `Comptez ${PERLES_PAR_LITRE} perles de céramique par litre d'eau. Dosage, première utilisation, entretien et régénération par ébullition : le guide complet des perles EM®.`;

// Dosage : la question n°1 sur Google (« combien de perles de céramique par litre d'eau »).
// Les chiffres viennent de src/data/dosages.ts, aligné sur le guide officiel.
const dosages = tousLesDosages.filter((d) =>
  ['boisson', 'electromenager'].includes(d.categorie)
);

const etapes = [
  {
    titre: 'Activez les perles (première utilisation)',
    texte: 'Faites bouillir vos perles 10 minutes dans de l\'eau claire pour les activer, puis placez-les dans votre contenant rempli d\'eau du robinet et attendez 30 minutes. Cette étape ne se fait qu\'une seule fois.',
  },
  {
    titre: 'Laissez-les agir au quotidien',
    texte: 'Les perles restent en permanence au fond de votre carafe, gourde ou appareil. Remplissez, l\'eau s\'améliore en continu : moins de goût de chlore, moins de tartre, un goût plus doux. Aucune attente après la première utilisation.',
  },
  {
    titre: 'Régénérez tous les 3 à 6 mois',
    texte: 'Faites bouillir les perles 10 à 15 minutes dans de l\'eau claire, sans savon ni détergent. Cette ébullition leur redonne toute leur efficacité. À répéter selon la dureté de votre eau et votre fréquence d\'utilisation.',
  },
];

const faqItems = [
  {
    question: 'Combien de perles de céramique par litre d\'eau ?',
    answer:
      `Comptez ${PERLES_PAR_LITRE} perles de céramique par litre d'eau de boisson. Concrètement : 15 perles pour une carafe de 1 L, 30 perles pour une carafe de 2 L, 75 perles pour une bonbonne de 5 L. Les appareils ont un dosage forfaitaire : 25 perles pour une bouilloire ou une cafetière, 40 pour un lave-vaisselle, 50 pour un lave-linge.`,
  },
  {
    question: 'Comment utiliser les perles de céramique pour la première fois ?',
    answer:
      'Faites-les bouillir 10 minutes dans de l\'eau claire pour les activer, puis placez-les au fond de votre contenant rempli d\'eau du robinet et attendez 30 minutes avant de boire. Ensuite, aucune attente n\'est nécessaire.',
  },
  {
    question: 'Comment nettoyer et régénérer les perles de céramique ?',
    answer:
      'Faites-les bouillir 10 à 15 minutes dans de l\'eau claire, sans savon, sans détergent et sans vinaigre. Répétez tous les 3 à 6 mois. Si un dépôt blanc apparaît (calcaire), l\'ébullition suffit à le faire disparaître.',
  },
  {
    question: 'Quels sont les effets des perles de céramique sur l\'eau ?',
    answer:
      'Elles réduisent le goût et l\'odeur de chlore, limitent les dépôts de tartre sur les parois et les résistances, et adoucissent le goût de l\'eau. Elles n\'éliminent pas les bactéries ni les métaux lourds — voir notre article avis & science pour le détail de ce qui est prouvé.',
  },
  {
    question: 'Combien de temps durent les perles de céramique ?',
    answer:
      'Plusieurs années avec une régénération régulière. Contrairement aux cartouches de carafe filtrante, il n\'y a rien à racheter chaque mois : c\'est un achat unique.',
  },
  {
    question: 'Peut-on mettre les perles de céramique au lave-vaisselle ou dans la machine à laver ?',
    answer:
      'Oui. Comptez 40 perles dans un filet placé en permanence dans le panier à couverts du lave-vaisselle, et 50 perles dans un filet de lavage directement dans le tambour du lave-linge. Elles limitent le calcaire et permettent de réduire la dose de détergent, de lessive et d\'adoucissant.',
  },
];

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Comment utiliser les perles de céramique EM®',
  description: metaDescription,
  step: etapes.map((e, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: e.titre,
    text: e.texte,
  })),
};

const jsonLd = [howToSchema, buildFaqSchema(faqItems)];
---

<BaseLayout title={metaTitle} description={metaDescription} jsonLd={jsonLd}>
  <!-- HERO -->
  <section class="bg-[#F5F0E8] px-4 pt-12 pb-14">
    <div class="max-w-3xl mx-auto">
      <p class="text-xs tracking-[0.3em] uppercase text-[#75592F] mb-4">Mode d'emploi</p>
      <h1 class="font-display text-4xl lg:text-5xl text-[#1A1A16] leading-[1.1] mb-5">
        Comment utiliser les perles de céramique ? Le guide complet
      </h1>
      <p class="text-[#57534e] text-lg leading-relaxed">
        Dosage par litre, première utilisation, entretien, régénération : tout ce qu'il faut
        savoir pour tirer le meilleur de vos perles EM® — en 3 étapes et quelques minutes.
      </p>
      <PageDate date={datePublished} class="mt-5" />
    </div>
  </section>

  <!-- VISUEL -->
  <div class="bg-[#F5F0E8] px-4 pb-14">
    <div class="max-w-3xl mx-auto">
      <Image
        src={getProductImage(photoSlug)!}
        alt={getProductImageAlt(photoSlug)}
        width={560}
        widths={[320, 560, 1120]}
        sizes="(max-width: 640px) 90vw, 560px"
        loading="eager"
        fetchpriority="high"
        class="w-full max-w-[440px] mx-auto rounded-2xl"
      />
    </div>
  </div>

  <AnswerBox>
    Comptez <strong class="text-[#1A1A16]">15 perles par litre</strong> d'eau de boisson.
    Rincez-les, déposez-les au fond de la carafe et laissez agir 30 minutes avant la
    première utilisation : elles restent ensuite en permanence dans l'eau. Tous les 3 à
    6 mois, régénérez-les en les faisant <strong class="text-[#1A1A16]">bouillir 10 à 15
    minutes</strong> dans de l'eau claire, sans savon ni vinaigre.
  </AnswerBox>

  <!-- 3 ÉTAPES -->
  <section class="py-16 px-4 bg-white" aria-labelledby="etapes-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="etapes-titre" class="font-display text-3xl text-[#1A1A16] mb-8">Les 3 étapes essentielles</h2>
      <ol class="space-y-8">
        {etapes.map((e, i) => (
          <li class="flex gap-5">
            <span class="font-display text-3xl text-[#9C8358] font-bold leading-none flex-shrink-0 w-12" aria-hidden="true">
              0{i + 1}
            </span>
            <div>
              <h3 class="font-semibold text-lg text-[#1A1A16] mb-2">{e.titre}</h3>
              <p class="text-[#57534e] leading-relaxed">{e.texte}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- DOSAGE -->
  <section class="py-16 px-4 bg-[#F5F0E8]" aria-labelledby="dosage-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="dosage-titre" class="font-display text-3xl text-[#1A1A16] mb-4">Combien de perles par litre d'eau ?</h2>
      <p class="text-[#57534e] mb-8">
        La règle simple : <strong class="text-[#1A1A16]">{PERLES_PAR_LITRE} perles par litre</strong>
        d'eau de boisson. Les appareils électroménagers ont, eux, un dosage forfaitaire :
      </p>
      <div class="overflow-x-auto rounded-2xl border border-[#D4C9B8] bg-white">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="bg-[#0D2818] text-white">
              <th scope="col" class="px-5 py-3.5 font-semibold">Contenant</th>
              <th scope="col" class="px-5 py-3.5 font-semibold">Nombre de perles</th>
              <th scope="col" class="px-5 py-3.5 font-semibold">Pack adapté</th>
            </tr>
          </thead>
          <tbody>
            {dosages.map((d, i) => (
              <tr class={i % 2 ? 'bg-[#FDFBF7]' : 'bg-white'}>
                <td class="px-5 py-3.5 text-[#57534e]">{d.usage}</td>
                <td class="px-5 py-3.5 font-semibold text-[#1A1A16]">{d.nb}</td>
                <td class="px-5 py-3.5">
                  {d.packSlug ? (
                    <a href={`/perles-ceramique-em/${d.packSlug}/`} class="font-semibold text-[#166534] hover:underline">{d.packLabel}</a>
                  ) : (
                    <span class="text-[#75592F]">—</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-sm text-[#57534e] mt-4">
        Les perles servent aussi hors de la cuisine — réfrigérateur, baignoire, arrosage,
        aquarium, piscine : retrouvez les 16 usages détaillés dans notre
        <a href="/utilisations/" class="text-[#166534] font-semibold hover:underline">guide des utilisations</a>.
      </p>
    </div>
  </section>

  <!-- CE QUE ÇA FAIT / NE FAIT PAS -->
  <section class="py-16 px-4 bg-white" aria-labelledby="effets-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="effets-titre" class="font-display text-3xl text-[#1A1A16] mb-8">Ce que les perles font — et ne font pas</h2>
      <div class="grid sm:grid-cols-2 gap-5">
        <div class="rounded-2xl border border-[#D4E4D0] bg-[#F4F9F2] p-6">
          <p class="font-semibold text-[#166534] mb-3">✓ Ce qu'elles font</p>
          <ul class="space-y-2 text-sm text-[#57534e]">
            <li>Réduisent le goût et l'odeur de chlore</li>
            <li>Limitent les dépôts de tartre</li>
            <li>Adoucissent le goût de l'eau</li>
            <li>Durent des années (achat unique)</li>
            <li>Zéro déchet, zéro plastique</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-[#EDE8E0] bg-[#FDFBF7] p-6">
          <p class="font-semibold text-[#75592F] mb-3">✗ Ce qu'elles ne font pas</p>
          <ul class="space-y-2 text-sm text-[#57534e]">
            <li>Éliminer bactéries et virus</li>
            <li>Filtrer métaux lourds, nitrates, pesticides</li>
            <li>Rendre potable une eau qui ne l'est pas</li>
          </ul>
          <p class="text-xs text-[#57534e] mt-4">
            On vous explique pourquoi, sources à l'appui, dans notre article
            <a href="/blog/les-bienfaits-des-perles-de-ceramique/" class="text-[#166534] font-semibold hover:underline">avis & science</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Faq items={faqItems} title="Vos questions sur l'utilisation" />
  <RelatedArticles currentHref={PATH} />
  <CtaPacks />
</BaseLayout>
