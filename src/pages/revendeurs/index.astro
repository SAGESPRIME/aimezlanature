---
/**
 * Page revendeur (B2B) — boutiques bio et vendeurs professionnels.
 *
 * Volontairement une page unique et non un cluster de contenu : la recherche
 * DataForSEO du 23/07/2026 montre zéro volume sur « grossiste perles de
 * céramique », « perles de céramique en gros » et « revendeur produits
 * écologiques ». Son trafic ne viendra pas de Google mais du lien en pied de
 * page et du démarchage direct — d'où une page conçue pour convaincre, pas
 * pour ranker.
 *
 * Absente du menu principal : elle ne doit pas polluer le parcours des clients
 * particuliers.
 *
 * Toutes les données viennent de src/data/revendeur.ts. Aucun tarif n'est
 * affiché tant que le marchand n'a pas validé sa grille (voir la règle en tête
 * de ce fichier de données).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Faq from '../../components/Faq.astro';
import RevendeurForm from '../../components/RevendeurForm.astro';
import { SITE } from '../../data/products';
import { buildFaqSchema } from '../../lib/seo';
import { argumentsRevente, etapes, faqPro, paliersRemise } from '../../data/revendeur';

const metaTitle = 'Devenir revendeur — Perles de Céramique EM® | Aimez la Nature';
const metaDescription =
  'Boutiques bio, épiceries vrac, praticiens : revendez les Perles de Céramique EM® japonaises. Remise progressive selon le volume, devis sous 24 h.';

const jsonLd = buildFaqSchema(faqPro);
// Virgule décimale française : `4.8` s'écrit « 4,8 » en toutes lettres sur la page.
const noteFr = SITE.globalRating.toString().replace('.', ',');
const noteAmazonFr = SITE.amazon.rating.toString().replace('.', ',');
---

<BaseLayout title={metaTitle} description={metaDescription} jsonLd={jsonLd}>
  <!-- HERO -->
  <section class="bg-[#0D2818] px-4 py-16 text-[#E8EFE4] lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="mb-4 text-xs uppercase tracking-[0.3em] text-[#A8C4A0]">Espace professionnels</p>
      <h1 class="font-display mb-6 text-4xl leading-[1.1] text-[#F5F0E8] lg:text-5xl">
        Revendez les Perles de Céramique EM® dans votre boutique
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-[#C9D6C4]">
        Marque française depuis {SITE.foundingYear}, revendeur agréé EM, perles authentiques
        importées du Japon. Nous ouvrons notre catalogue aux boutiques bio, épiceries vrac,
        praticiens et commerçants qui veulent proposer une alternative crédible aux carafes
        filtrantes.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="#demande-titre"
          class="inline-flex rounded-full bg-[#A8C4A0] px-7 py-3.5 text-sm font-semibold text-[#0D2818] transition-colors hover:bg-[#F5F0E8]"
        >
          Recevoir la grille revendeur
        </a>
        <a
          href="/perles-ceramique-em/"
          class="inline-flex rounded-full border border-[#A8C4A0]/50 px-7 py-3.5 text-sm font-semibold text-[#E8EFE4] transition-colors hover:bg-white/10"
        >
          Voir le catalogue
        </a>
      </div>
    </div>
  </section>

  <!-- POURQUOI ÇA TOURNE EN RAYON -->
  <section class="bg-white px-4 py-16" aria-labelledby="arguments-titre">
    <div class="mx-auto max-w-4xl">
      <p class="mb-3 text-xs uppercase tracking-[0.3em] text-[#6E5330]">L'intérêt pour vous</p>
      <h2 id="arguments-titre" class="font-display mb-4 text-3xl text-[#1A1A16] lg:text-4xl">
        Un produit qui se vend sans forcer
      </h2>
      <p class="mb-10 max-w-2xl leading-relaxed text-[#57534e]">
        {`${SITE.totalReviews} avis vérifiés sur nos fiches (${noteFr}/5) et ${SITE.amazon.reviewCount} commentaires sur Amazon (${noteAmazonFr}/5) :`}
        le produit a déjà fait ses preuves auprès du grand public avant d'arriver dans votre rayon.
      </p>

      {/* Pas de [data-reveal] sur ces cartes ni sur les étapes plus bas :
          global.css avertit qu'un bloc porteur de l'argumentaire resterait à
          opacity 0 tant que site.js n'a pas tourné. Les cartes produits de
          l'accueil en ont été retirées pour la même raison — un revendeur doit
          voir ces arguments sans condition. */}
      <div class="grid gap-5 sm:grid-cols-2">
        {argumentsRevente.map((a) => (
          <div class="rounded-2xl border border-[#EDE8E0] bg-[#FBF9F5] p-6">
            <h3 class="font-display mb-2 text-xl text-[#1A1A16]">{a.titre}</h3>
            <p class="text-sm leading-relaxed text-[#57534e]">{a.texte}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VOTRE REMISE -->
  <section class="bg-[#F5F0E8] px-4 py-16" aria-labelledby="remise-titre">
    <div class="mx-auto max-w-3xl">
      <p class="mb-3 text-xs uppercase tracking-[0.3em] text-[#6E5330]">Vos conditions</p>
      <h2 id="remise-titre" class="font-display mb-5 text-3xl text-[#1A1A16] lg:text-4xl">
        Une remise qui progresse avec votre volume
      </h2>

      {paliersRemise.length > 0 ? (
        <div class="overflow-x-auto rounded-2xl border border-[#D4C9B8] bg-white">
          <table class="w-full text-left text-sm">
            <thead class="border-b border-[#EDE8E0] text-[#1A1A16]">
              <tr>
                <th scope="col" class="px-5 py-4 font-semibold">Palier</th>
                <th scope="col" class="px-5 py-4 font-semibold">À partir de</th>
                <th scope="col" class="px-5 py-4 font-semibold">Remise</th>
              </tr>
            </thead>
            <tbody class="text-[#57534e]">
              {paliersRemise.map((p) => (
                <tr class="border-b border-[#EDE8E0] last:border-0">
                  <td class="px-5 py-4 font-semibold text-[#1A1A16]">{p.nom}</td>
                  <td class="px-5 py-4">{p.condition}</td>
                  <td class="px-5 py-4 font-semibold text-[#166534]">{p.remise}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="rounded-2xl border border-[#D4C9B8] bg-white p-6 sm:p-8">
          <p class="leading-relaxed text-[#57534e]">
            Plus votre commande est importante, plus votre remise l'est. Nous ne publions pas
            notre grille en ligne : elle est établie en fonction de votre activité et du volume
            que vous envisagez, puis transmise avec votre devis sous 24 h ouvrées.
          </p>
          <p class="mt-4 leading-relaxed text-[#57534e]">
            Le réassort se fait à la commande, sans engagement de volume annuel.
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- COMMENT ÇA SE PASSE -->
  <section class="bg-white px-4 py-16" aria-labelledby="etapes-titre">
    <div class="mx-auto max-w-3xl">
      <p class="mb-3 text-xs uppercase tracking-[0.3em] text-[#6E5330]">Le déroulé</p>
      <h2 id="etapes-titre" class="font-display mb-8 text-3xl text-[#1A1A16] lg:text-4xl">
        Comment ça se passe
      </h2>
      <ol class="space-y-5">
        {etapes.map((e, i) => (
          <li class="flex gap-4">
            <span
              class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-[#166534] text-sm font-bold text-white"
              aria-hidden="true"
            >
              {i + 1}
            </span>
            <div>
              <h3 class="mb-1 font-semibold text-[#1A1A16]">{e.titre}</h3>
              <p class="text-sm leading-relaxed text-[#57534e]">{e.texte}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <Faq items={faqPro} title="Questions des professionnels" eyebrow="FAQ pro" />

  <RevendeurForm />
</BaseLayout>
