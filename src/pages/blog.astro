---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/products';
import { blogPosts } from '../data/blogPosts';

// Titres et description repris de la version aimezlanature.vercel.app/blog.
const metaTitle = 'Blog Perles de Céramique EM | Aimez la Nature';
const metaDescription =
  "Articles et guides sur les perles de céramique EM, la purification naturelle de l'eau et les micro-organismes efficaces. Conseils, comparatifs et astuces.";

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Blog — Aimez la Nature',
    description: metaDescription,
    inLanguage: 'fr-FR',
    url: `${SITE.url}/blog/`,
    isPartOf: { '@type': 'WebSite', name: SITE.name, url: SITE.url },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Articles du blog Aimez la Nature',
    itemListElement: blogPosts.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: post.title,
      url: `${SITE.url}${post.href}`,
    })),
  },
];

// UTC forcé : sans cela, un serveur à l'ouest de Greenwich afficherait la veille.
function formatDate(iso: string): string {
  return new Date(`${iso}T00:00:00Z`).toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
    timeZone: 'UTC',
  });
}
---

<BaseLayout title={metaTitle} description={metaDescription} jsonLd={jsonLd}>
  <!-- EN-TÊTE — titre centré + sous-titre, comme la version d'origine -->
  <section class="bg-[#F5F0E8] px-4 pt-16 pb-14">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="font-display text-4xl lg:text-5xl text-[#1A1A16] leading-[1.15] mb-5">
        Blog — Perles de Céramique EM et Purification de l'Eau
      </h1>
      <p class="text-[#57534e] text-lg leading-relaxed">
        Guides, conseils et comparatifs sur les perles de céramique EM et la
        purification naturelle de l'eau.
      </p>
    </div>
  </section>

  <!-- GRILLE D'ARTICLES — cartes blanches 2 colonnes -->
  <section class="py-14 px-4 bg-[#FDFBF7]" aria-labelledby="articles-titre">
    <h2 id="articles-titre" class="sr-only">Tous les articles</h2>
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-6">
      {blogPosts.map((post) => (
        <article class="flex flex-col rounded-2xl border border-[#EDE8E0] bg-white p-6 transition-colors hover:border-[#C4B89A]">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-flex items-center rounded-full bg-[#D4E4D0] px-3 py-1 text-xs font-semibold text-[#166534]">
              {post.category}
            </span>
            <span class="inline-flex items-center gap-1.5 text-xs text-[#75592F]">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v5l3 2" stroke-linecap="round" />
              </svg>
              {post.readingTime} de lecture
            </span>
          </div>

          <h3 class="font-display text-2xl text-[#1A1A16] leading-snug mb-3">
            <a href={post.href} class="hover:text-[#166534] transition-colors">{post.title}</a>
          </h3>

          <p class="text-[#57534e] text-sm leading-relaxed mb-6">{post.excerpt}</p>

          <div class="mt-auto flex items-center justify-between border-t border-[#EDE8E0] pt-4">
            <time datetime={post.date} class="text-xs text-[#75592F]">
              {formatDate(post.date)}
            </time>
            <a
              href={post.href}
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-[#166534] hover:gap-3 transition-all"
            >
              Lire <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
