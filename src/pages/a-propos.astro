---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaPacks from '../components/CtaPacks.astro';
import { SITE } from '../data/products';

// Histoire réelle de la fondatrice, reprise de la page « Qui sommes-nous ? »
// d'aimezlanature.fr (relevée le 2026-07-20). Les allégations santé du texte
// original (« guérison complète ») sont volontairement écartées : on raconte
// le parcours, on ne promet aucun effet thérapeutique.
const etapes = [
  {
    annee: '2008',
    titre: 'Le déclic',
    texte: 'Tout part d\'un geste banal : une lessive. Une réaction cutanée sévère pousse notre fondatrice à regarder de près la composition des produits du quotidien — et à ne plus jamais les considérer comme anodins.',
  },
  {
    annee: '2013',
    titre: 'Le virage naturel',
    texte: 'Après des années de traitements conventionnels décevants, elle explore les alternatives naturelles — miel de Manuka, vinaigre de cidre non pasteurisé — et repense tout son mode de vie : « un esprit sain dans un corps sain », y compris dans ce qu\'on boit. Les bouteilles plastique sortent de son quotidien.',
  },
  {
    annee: '2019',
    titre: 'La rencontre avec les perles',
    texte: 'Elle découvre les perles de céramique EM : un objet simple, durable, qui améliore l\'eau du robinet sans cartouche ni plastique. L\'évidence : c\'est cette solution-là qu\'il faut faire connaître.',
  },
  {
    annee: '2020',
    titre: 'Naissance d\'Aimez la Nature',
    texte: 'La marque est créée et déposée à l\'INPI (n° 4664991, publiée le 31 juillet 2020), avec une mission claire : rendre les trésors simples de la nature accessibles à tous, en commençant par l\'eau.',
  },
];

const metaTitle = 'Notre mission : une eau meilleure, sans plastique | Aimez la Nature';
const metaDescription =
  'Aimez la Nature : des Perles de Céramique EM® japonaises authentiques, un emballage zéro plastique et une ligne honnête sur ce que les perles font — et ne font pas.';

const engagements = [
  {
    titre: 'Des perles EM® authentiques',
    texte: 'Nos perles sont fabriquées au Japon selon le procédé EM® original du professeur Teruo Higa. Pas de copies génériques : la certification EM® garantit la composition et le processus de fabrication.',
  },
  {
    titre: 'Zéro plastique, du produit au colis',
    texte: 'Tube biodégradable, sachet en coton BIO certifié, emballage d\'expédition en papier recyclé. Un produit qui sert à supprimer les bouteilles plastique ne peut pas arriver emballé dedans.',
  },
  {
    titre: 'De l\'honnêteté avant tout',
    texte: 'Nos pages disent ce que les perles font — goût, chlore ressenti, tartre — et ce qu\'elles ne font pas : bactéries, métaux lourds, pesticides. Vendre correctement, c\'est d\'abord informer correctement.',
  },
  {
    titre: 'Un service client qui répond',
    texte: 'Une question sur le dosage, une commande, un retour : nous répondons sous 24 h ouvrées, par email ou par téléphone. Pas de robot, pas de ticket perdu.',
  },
];

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: metaTitle,
  description: metaDescription,
  url: `${SITE.url}/a-propos/`,
  mainEntity: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    description: SITE.description,
    // Création de la marque en 2019 (source : le marchand). À ne pas confondre
    // avec le dépôt INPI n° 4664991, publié le 31/07/2020 — c'est la date
    // d'enregistrement de la marque, pas celle du début d'activité.
    foundingDate: String(SITE.foundingYear),
    sameAs: [SITE.amazon.url],
  },
};
---

<BaseLayout title={metaTitle} description={metaDescription} jsonLd={aboutSchema}>
  <!-- HERO -->
  <section class="bg-[#F5F0E8] px-4 pt-12 pb-14">
    <div class="max-w-3xl mx-auto">
      <p class="text-xs tracking-[0.3em] uppercase text-[#75592F] mb-4">À propos</p>
      <h1 class="font-display text-4xl lg:text-5xl text-[#1A1A16] leading-[1.1] mb-5">
        Une eau meilleure, <em class="not-italic text-[#166534]">sans plastique</em>
      </h1>
      <p class="text-[#57534e] text-lg leading-relaxed">
        Aimez la Nature est née d'un constat simple : en France, on jette des millions de
        bouteilles plastique pour éviter un goût de chlore. Notre mission est de rendre
        l'eau du robinet assez agréable pour que ces bouteilles deviennent inutiles.
      </p>
    </div>
  </section>

  <!-- HISTOIRE / TIMELINE -->
  <section class="py-14 px-4 bg-white" aria-labelledby="histoire-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="histoire-titre" class="font-display text-3xl text-[#1A1A16] mb-3">D'où vient Aimez la Nature</h2>
      <p class="text-[#57534e] leading-relaxed mb-10">
        La marque n'est pas née dans un bureau marketing, mais d'un parcours personnel
        de douze ans — celui de sa fondatrice, guidée par une conviction qu'elle résume
        en une phrase : <em class="text-[#1A1A16]">« la nature ne se trompe jamais »</em>.
      </p>
      <ol class="space-y-8 mb-4">
        {etapes.map((e) => (
          <li class="flex gap-6">
            <span class="font-display text-2xl text-[#9C8358] font-bold leading-none flex-shrink-0 w-16 pt-0.5" aria-hidden="true">{e.annee}</span>
            <div>
              <h3 class="font-semibold text-lg text-[#1A1A16] mb-1">{e.titre}</h3>
              <p class="text-[#57534e] text-sm leading-relaxed">{e.texte}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- POURQUOI LES PERLES -->
  <section class="py-14 px-4 bg-[#FDFBF7]" aria-labelledby="pourquoi-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="pourquoi-titre" class="font-display text-3xl text-[#1A1A16] mb-6">Pourquoi les perles de céramique ?</h2>
      <p class="text-[#57534e] leading-relaxed mb-4">
        Parce que c'est la solution la plus sobre que nous ayons trouvée : un objet unique, fabriqué
        en argile naturelle, qui dure des années, ne demande ni cartouche, ni électricité, ni
        plastique — et qui se régénère avec une simple casserole d'eau bouillante.
      </p>
      <p class="text-[#57534e] leading-relaxed mb-4">
        Nous avons choisi les perles EM® japonaises authentiques plutôt que des copies, parce que
        la qualité de l'argile et du processus de fermentation fait la différence entre un produit
        qui agit et un simple caillou décoratif.
      </p>
      <p class="text-[#57534e] leading-relaxed">
        Aujourd'hui, {SITE.totalReviews} clients nous font confiance, avec une note moyenne de
        {SITE.globalRating.toString().replace('.', ',')}/5. Notre meilleure publicité reste leur
        eau du matin.
      </p>
    </div>
  </section>

  <!-- ENGAGEMENTS -->
  <section class="py-14 px-4 bg-[#F5F0E8]" aria-labelledby="engagements-titre">
    <div class="max-w-4xl mx-auto">
      <h2 id="engagements-titre" class="font-display text-3xl text-[#1A1A16] mb-8">Nos quatre engagements</h2>
      <div class="grid sm:grid-cols-2 gap-5">
        {engagements.map((e, i) => (
          <div class="bg-white rounded-2xl border border-[#EDE8E0] p-6">
            <p class="font-display text-2xl text-[#9C8358] font-bold mb-2" aria-hidden="true">0{i + 1}</p>
            <h3 class="font-semibold text-[#1A1A16] mb-2">{e.titre}</h3>
            <p class="text-sm text-[#57534e] leading-relaxed">{e.texte}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="py-14 px-4 bg-[#0D2818] text-white" aria-labelledby="mission-titre">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs tracking-[0.3em] uppercase text-[#A8C4A0] mb-4">Notre mission</p>
      <h2 id="mission-titre" class="font-display text-3xl lg:text-4xl mb-6">Moins de plastique, une eau meilleure</h2>
      <p class="text-[#B8CCB4] leading-relaxed">
        Chaque foyer qui passe aux perles, c'est de l'eau en bouteille qui n'est plus achetée,
        du plastique qui n'est plus jeté et des cartouches qui ne sont plus remplacées.
        C'est modeste à l'échelle d'une maison — et considérable à l'échelle de milliers.
      </p>
    </div>
  </section>

  <CtaPacks />
</BaseLayout>
