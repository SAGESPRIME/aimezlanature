---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Faq from '../../components/Faq.astro';
import AnswerBox from '../../components/AnswerBox.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import PageDate from '../../components/PageDate.astro';
import CtaPacks from '../../components/CtaPacks.astro';
import { buildArticleSchema, buildFaqSchema } from '../../lib/seo';
import { getProductImage, getProductImageAlt } from '../../lib/productImages';

// Chemin et date définis une seule fois : partagés par le schema Article et
// par l'affichage, pour qu'ils ne puissent pas diverger.
const PATH = '/blog/perles-de-ceramique-em-authentiques/';
const datePublished = '2026-07-20';

// L'emballage réel (tube carton + sachet coton) est précisément ce que
// l'article décrit comme signe d'authenticité.
const photoSlug = 'pack-100-perles';

const metaTitle = 'Perles de céramique EM authentiques : le guide | Aimez la Nature';
const metaDescription =
  'Que veut dire EM® ? Comment les perles de céramique sont-elles fabriquées, et comment distinguer les authentiques des copies génériques ? Le guide complet.';

// Les 5 familles de micro-organismes du procédé EM® (Pr Teruo Higa) — repris de
// l'ancien article « Authenticité des perles de céramique EM » du blog historique,
// seule partie factuelle conservée lors de la consolidation.
const familles = [
  { nom: 'Bactéries lactiques', role: 'Les mêmes familles que dans un yaourt ou une choucroute : elles acidifient le milieu de fermentation et inhibent les organismes indésirables.' },
  { nom: 'Levures', role: 'Présentes dans le pain ou la bière : elles produisent des enzymes et participent à la fermentation de l\'argile.' },
  { nom: 'Bactéries photosynthétiques', role: 'La signature du procédé EM® : elles travaillent en synergie avec les autres familles pendant la fermentation.' },
  { nom: 'Actinomycètes', role: 'Des bactéries du sol, connues pour l\'odeur de terre après la pluie, qui contribuent à l\'équilibre du mélange.' },
  { nom: 'Champignons de fermentation', role: 'Du type de ceux utilisés pour le miso ou la sauce soja, ils complètent la communauté microbienne.' },
];

const signes = [
  { signe: 'La mention du procédé EM®', detail: 'Les perles authentiques revendiquent explicitement la technologie EM® (Effective Microorganisms), développée au Japon. Une fiche produit qui parle seulement de « céramique » ou d\'« argile » sans référence au procédé EM est probablement une copie générique.' },
  { signe: 'Une provenance affichée', detail: 'Fabrication au Japon (ou sous licence du procédé original) clairement indiquée. Méfiance quand aucune origine n\'est donnée.' },
  { signe: 'Un prix cohérent', detail: 'La fermentation et la cuisson du procédé original ont un coût : des perles à quelques centimes pièce en marketplace, sans marque ni origine, sont rarement des EM® authentiques.' },
  { signe: 'Des promesses honnêtes', detail: 'Paradoxalement, c\'est un bon test : les vendeurs sérieux disent ce que les perles ne font PAS (bactéries, métaux lourds). Fuyez les fiches qui promettent une eau « purifiée à 100 % » ou « dynamisée ».' },
];

const faqItems = [
  {
    question: 'Que signifie EM dans « perles de céramique EM » ?',
    answer:
      'EM signifie Effective Microorganisms (micro-organismes efficaces) : un consortium de micro-organismes naturels — bactéries lactiques, levures, bactéries photosynthétiques, actinomycètes et champignons de fermentation — mis au point dans les années 1980 par le professeur Teruo Higa, à l\'université des Ryūkyūs au Japon, d\'abord pour l\'agriculture.',
  },
  {
    question: 'Comment les perles de céramique EM sont-elles fabriquées ?',
    answer:
      'De l\'argile est ensemencée avec la préparation de micro-organismes EM, mise à fermenter, façonnée en petits cylindres puis cuite à haute température. La cuisson fige la matière : le produit fini est une céramique poreuse inerte — les micro-organismes ne sont plus vivants dans la perle que vous mettez dans l\'eau.',
  },
  {
    question: 'Les micro-organismes des perles sont-ils dangereux ?',
    answer:
      'Non. Les familles utilisées (lactobacilles, levures…) sont celles de l\'alimentation fermentée, et elles ne survivent pas à la cuisson sous forme active. Boire l\'eau d\'une carafe équipée de perles ne revient pas à « boire des bactéries » — le détail est dans notre page Avis & science.',
  },
  {
    question: 'Des perles génériques sans EM fonctionnent-elles aussi ?',
    answer:
      'Une céramique poreuse quelconque peut avoir un léger effet d\'adsorption, mais c\'est la qualité de l\'argile, la fermentation EM et la cuisson qui font la différence constatée sur le goût et le tartre. C\'est tout l\'enjeu de vérifier ce qu\'on achète : deux produits visuellement identiques peuvent avoir des procédés très différents.',
  },
  {
    question: 'Les perles Aimez la Nature sont-elles authentiques ?',
    answer:
      'Nos perles sont fabriquées au Japon selon le procédé EM® original. C\'est le critère qui a fondé la marque : plutôt qu\'une copie moins chère, un produit dont le procédé de fabrication est celui d\'origine — et une communication qui dit honnêtement ce que les perles font et ne font pas.',
  },
];

const jsonLd = [
  buildArticleSchema({
    headline: 'Perles de céramique EM authentiques : comment les reconnaître',
    description: metaDescription,
    path: PATH,
    datePublished,
  }),
  buildFaqSchema(faqItems),
];
---

<BaseLayout title={metaTitle} description={metaDescription} jsonLd={jsonLd}>
  <!-- HERO -->
  <section class="bg-[#F5F0E8] px-4 pt-12 pb-14">
    <div class="max-w-3xl mx-auto">
      <p class="text-xs tracking-[0.3em] uppercase text-[#75592F] mb-4">Authenticité · Article</p>
      <h1 class="font-display text-4xl lg:text-5xl text-[#1A1A16] leading-[1.1] mb-5">
        Perles de céramique EM authentiques : comment les reconnaître
      </h1>
      <p class="text-[#57534e] text-lg leading-relaxed">
        « EM », ce n'est pas un argument marketing : c'est un procédé de fermentation précis,
        né au Japon. Voici ce qu'il recouvre exactement — et les signes qui distinguent les
        perles authentiques des copies génériques vendues au même prix.
      </p>
      <PageDate date={datePublished} class="mt-5" />
    </div>
  </section>

  <!-- VISUEL -->
  <div class="bg-[#F5F0E8] px-4 pb-14">
    <div class="max-w-3xl mx-auto">
      <Image
        src={getProductImage(photoSlug)!}
        alt={getProductImageAlt(photoSlug)}
        width={560}
        widths={[320, 560, 1120]}
        sizes="(max-width: 640px) 90vw, 560px"
        loading="eager"
        fetchpriority="high"
        class="w-full max-w-[440px] mx-auto rounded-2xl"
      />
    </div>
  </div>

  <!-- RÉPONSE COURTE (bloc GEO) -->
  <AnswerBox>
    Des perles de céramique EM authentiques sont fabriquées à partir d'argile fermentée
    avec les micro-organismes efficaces (EM®) du procédé du professeur Teruo Higa, puis
    cuites à haute température. Pour les reconnaître : la mention explicite du procédé
    EM®, une provenance affichée (Japon ou licence officielle), un prix cohérent avec
    ce procédé, et des promesses honnêtes sur ce que les perles font — et ne font pas.
  </AnswerBox>

  <!-- CE QUE VEUT DIRE EM -->
  <section class="py-14 px-4 bg-[#F5F0E8]" aria-labelledby="em-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="em-titre" class="font-display text-3xl text-[#1A1A16] mb-4">Ce que veut dire « EM », exactement</h2>
      <p class="text-[#57534e] leading-relaxed mb-4">
        EM® (Effective Microorganisms) désigne un consortium de micro-organismes naturels mis
        au point dans les années 1980 par le professeur <strong class="text-[#1A1A16]">Teruo
        Higa</strong> à l'université des Ryūkyūs (Okinawa, Japon), d'abord pour régénérer les
        sols agricoles. Le procédé associe cinq familles de micro-organismes qui fermentent
        ensemble :
      </p>
      <div class="space-y-3 mb-6">
        {familles.map((f) => (
          <div class="rounded-2xl border border-[#EDE8E0] bg-white p-5">
            <p class="font-semibold text-[#1A1A16] mb-1">{f.nom}</p>
            <p class="text-sm text-[#57534e] leading-relaxed">{f.role}</p>
          </div>
        ))}
      </div>
      <p class="text-[#57534e] leading-relaxed">
        Pour les perles, cette préparation fermente avec de l'argile, qui est ensuite façonnée
        et <strong class="text-[#1A1A16]">cuite à haute température</strong>. Point important —
        et souvent mal expliqué : après cuisson, la perle est une céramique poreuse
        <strong class="text-[#1A1A16]">inerte</strong>. Ses effets constatés (goût, chlore
        ressenti, tartre) tiennent à cette porosité, pas à des micro-organismes vivants dans
        votre carafe. Ce que la science en dit précisément est détaillé dans notre page
        <a href="/perles-de-ceramique-avis/" class="text-[#166534] font-semibold hover:underline">Avis & science</a>.
      </p>
    </div>
  </section>

  <!-- LES SIGNES D'AUTHENTICITÉ -->
  <section class="py-14 px-4 bg-white" aria-labelledby="signes-titre">
    <div class="max-w-3xl mx-auto">
      <h2 id="signes-titre" class="font-display text-3xl text-[#1A1A16] mb-8">
        Les 4 signes d'une perle authentique
      </h2>
      <ol class="space-y-5">
        {signes.map((s, i) => (
          <li class="flex gap-5">
            <span class="font-display text-3xl text-[#9C8358] font-bold leading-none flex-shrink-0 w-10" aria-hidden="true">0{i + 1}</span>
            <div>
              <h3 class="font-semibold text-lg text-[#1A1A16] mb-1">{s.signe}</h3>
              <p class="text-[#57534e] text-sm leading-relaxed">{s.detail}</p>
            </div>
          </li>
        ))}
      </ol>
      <p class="text-sm text-[#57534e] bg-[#F5F0E8] rounded-2xl px-5 py-4 mt-8">
        Notre engagement là-dessus est le fondement de la marque : des perles fabriquées au
        Japon selon le procédé EM® original — et une communication qui assume aussi leurs
        limites. C'est raconté sur notre page
        <a href="/a-propos/" class="text-[#166534] font-semibold hover:underline">Notre mission</a>.
      </p>
    </div>
  </section>

  <Faq items={faqItems} title="Vos questions sur l'authenticité" />
  <RelatedArticles currentHref={PATH} />
  <CtaPacks />
</BaseLayout>
