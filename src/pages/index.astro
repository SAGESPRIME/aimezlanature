---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../data/products';
import { guides } from '../data/guides';
import { getProductImage, getProductImageAlt } from '../lib/productImages';

// Visuel du hero : le Pack 55, notre bestseller.
const heroPhoto = getProductImage('pack-55-perles');

const metaTitle = 'Perles Céramique EM® — Purifiez votre eau | Aimez la Nature';
const metaDescription =
  `Purifiez votre eau du robinet avec nos Perles de Céramique EM® japonaises. ${SITE.totalReviews} avis vérifiés, livraison offerte dès ${SITE.freeShippingThreshold}€, garantie 30 jours. Zéro plastique.`;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  logo: `${SITE.url}/logo.png`,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    telephone: '+33-1-84-80-15-22',
    email: 'contact@aimezlanature.fr',
    availableLanguage: 'French',
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: `${SITE.url}/perles-ceramique-em/?q={search_term_string}` },
    'query-input': 'required name=search_term_string',
  },
};

// Pas de schema Product « catalogue » avec note agrégée ici : Google exige
// qu'un aggregateRating porte sur un produit précis — agréger les avis de
// plusieurs produits dans un Product fictif violerait ses consignes.
// Les notes réelles restent dans le schema Product de chaque fiche.

const steps = [
  {
    num: '01',
    titre: 'Placez les perles dans votre eau',
    texte: 'Déposez les perles au fond de votre carafe, bouilloire ou gourde. Aucun montage, aucun raccordement.',
  },
  {
    num: '02',
    titre: 'L\'eau s\'améliore naturellement',
    texte: 'En 30 minutes, le chlore est réduit, le goût s\'adoucit, le tartre diminue. Efficacité sur 3 à 6 mois.',
  },
  {
    num: '03',
    titre: 'Régénérez par simple ébullition',
    texte: 'Faites bouillir les perles 10 à 15 minutes pour leur redonner toute leur efficacité. Répétez tous les 3-6 mois.',
  },
];

// Extraits d'avis clients RÉELS, copiés mot pour mot depuis le JSON-LD des
// fiches produit d'aimezlanature.fr (relevé le 2026-07-20, avis 5/5 publiés
// avec ces noms). Ne jamais remplacer par des témoignages rédigés : un avis
// invérifiable = pratique commerciale trompeuse (art. L121-2 Code conso).
const testimonials = [
  {
    name: 'Amine B.',
    pack: 'Pack 55',
    texte: 'Ces microbilles sont vraiment efficaces dans ma carafe, on ne sent plus du tout l\'odeur chlorée, de plus l\'eau est beaucoup plus douce.',
  },
  {
    name: 'Corine M.',
    pack: 'Pack 100',
    texte: 'J\'intègre ces perles céramiques dans ma bouilloire ainsi que dans ma machine à café : adieu le tartre et fini les produits anti-calcaire chimiques.',
  },
  {
    name: 'Patrick D.',
    pack: 'Pack 100',
    texte: 'Ces perles correspondent exactement à ce qui était décrit. Je constate une véritable amélioration de la qualité de l\'eau dans ma carafe.',
  },
];
---

<BaseLayout title={metaTitle} description={metaDescription} jsonLd={[organizationSchema, websiteSchema]}>

  <!-- ══════════════════════════════════
       HERO — split éditorial
  ══════════════════════════════════ -->
  <section class="min-h-[90vh] grid grid-cols-1 lg:grid-cols-2 bg-[#F5F0E8] w-full">
    <div class="flex flex-col justify-center px-8 lg:px-16 xl:px-24 py-16 lg:py-24">
      <p class="text-xs tracking-[0.3em] uppercase text-[#75592F] mb-6 font-medium">
        Perles de Céramique EM® · Fabriquées au Japon
      </p>
      <h1 class="font-display text-5xl lg:text-6xl xl:text-[4.5rem] text-[#1A1A16] leading-[1.05] mb-6">
        L'eau du robinet,<br />
        <em class="not-italic text-[#166534]">purifiée</em><br />
        naturellement.
      </h1>
      <p class="text-[#57534e] text-lg leading-relaxed max-w-md mb-8">
        Nos perles d'argile EM® réduisent le chlore, adoucissent l'eau et limitent
        le tartre — sans filtre, sans plastique, sans effort.
      </p>
      <div class="flex flex-wrap gap-4 mb-10">
        <a href="/perles-ceramique-em/" class="inline-flex items-center gap-2 bg-[#166534] text-white px-7 py-3.5 rounded-full font-semibold text-sm hover:bg-[#0D4A25] transition-colors">
          Purifier mon eau — dès 19,90 € <span aria-hidden="true">→</span>
        </a>
        <a href="/comment-ca-marche/" class="inline-flex items-center gap-2 border border-[#75592F] text-[#75592F] px-7 py-3.5 rounded-full font-semibold text-sm hover:bg-[#75592F] hover:text-white transition-colors">
          Comment ça marche ?
        </a>
      </div>
      <div class="flex flex-wrap items-center gap-5 text-sm text-[#57534e]">
        <div class="flex items-center gap-2">
          <span class="text-[#166534] font-bold" aria-label="Note 5 étoiles">★★★★★</span>
          <span><strong class="text-[#1A1A16]">{SITE.globalRating.toString().replace('.', ',')}/5</strong> · {SITE.totalReviews} avis</span>
        </div>
        <span class="w-px h-5 bg-[#D4C9B8]" aria-hidden="true"></span>
        <span>Livraison offerte dès 50€</span>
        <span class="w-px h-5 bg-[#D4C9B8]" aria-hidden="true"></span>
        <span>Garantie 30 jours</span>
      </div>
    </div>

    <div class="relative hidden lg:flex items-center justify-center bg-[#EDE8E0] overflow-hidden">
      <div class="relative w-[400px] h-[400px] xl:w-[460px] xl:h-[460px]">
        <div class="absolute inset-0 rounded-full border-2 border-[#C4B89A] opacity-30"></div>
        <div class="absolute inset-4 rounded-full border border-[#C4B89A] opacity-20"></div>
        <div class="absolute inset-0 rounded-full bg-[#F5F0E8] overflow-hidden">
          {heroPhoto && (
            <Image
              src={heroPhoto}
              alt={getProductImageAlt('pack-55-perles')}
              width={460}
              height={460}
              widths={[400, 460, 920]}
              sizes="460px"
              loading="eager"
              fetchpriority="high"
              class="w-full h-full object-cover"
            />
          )}
        </div>
      </div>
      <div class="absolute top-8 right-8 bg-white rounded-2xl px-4 py-3 shadow-sm border border-[#EDE8E0]">
        <p class="text-xs text-[#57534e]">Procédé EM® original</p>
        <p class="text-sm font-bold text-[#166534]">Fabriqué au Japon</p>
      </div>
      <div class="absolute bottom-12 left-8 bg-[#166534] text-white rounded-2xl px-4 py-3">
        <p class="text-xs opacity-75">Avis clients vérifiés</p>
        <p class="font-bold text-sm">{SITE.totalReviews} avis · {SITE.globalRating.toString().replace('.', ',')}/5</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════
       TRUST STRIP
  ══════════════════════════════════ -->
  <div class="bg-[#166534] text-white">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-wrap justify-center gap-6 lg:gap-10 text-sm font-medium">
      {([
        { icon: 'truck', label: 'Livraison offerte dès 50€' },
        { icon: 'refresh', label: 'Remboursement 30 jours' },
        { icon: 'leaf', label: 'Perles EM® authentiques' },
        { icon: 'droplet', label: 'Zéro plastique, zéro déchet' },
      ] as const).map(({ icon, label }) => (
        <span class="inline-flex items-center gap-2"><Icon name={icon} class="w-4 h-4 opacity-80" />{label}</span>
      ))}
    </div>
  </div>

  <!-- ══════════════════════════════════
       PRODUITS — bento asymétrique
  ══════════════════════════════════ -->
  <section class="py-20 px-4 bg-[#F5F0E8]" aria-labelledby="produits-titre">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12">
        <p class="text-xs tracking-[0.3em] uppercase text-[#75592F] mb-3">Nos packs</p>
        <h2 id="produits-titre" class="font-display text-4xl text-[#1A1A16]">Choisissez votre format</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4">

        <!-- Pack 55 — bestseller — 3/5 cols -->
        <a href="/perles-ceramique-em/pack-55-perles/" data-reveal class="md:col-span-3 relative rounded-3xl overflow-hidden p-8 lg:p-10 flex flex-col justify-between min-h-[300px] group transition-transform hover:scale-[1.01] bg-[#D4E4D0]">
          <span class="absolute right-4 top-2 font-display text-[140px] font-bold leading-none select-none opacity-[0.08] text-[#166534]" aria-hidden="true">55</span>
          <div>
            <span class="inline-block bg-[#166534] text-white text-xs font-semibold px-3 py-1 rounded-full mb-4">Bestseller · ★ 4,91/5 (45 avis)</span>
            <h3 class="font-display text-3xl text-[#1A1A16] mb-2">Pack 55 Perles</h3>
            <p class="text-[#57534e] text-sm max-w-xs">Idéal carafe 1,5-2 L, bouilloire, machine à café. Le choix de 45 clients satisfaits.</p>
          </div>
          <div class="flex items-end justify-between mt-6">
            <div>
              <p class="text-xs text-[#75592F] line-through">25,90€</p>
              <p class="font-display text-3xl text-[#166534] font-bold">19,90€</p>
            </div>
            <span class="bg-[#166534] text-white px-5 py-2.5 rounded-full text-sm font-semibold group-hover:bg-[#0D4A25] transition-colors">Commander →</span>
          </div>
        </a>

        <!-- Pack 100 — 2/5 cols -->
        <a href="/perles-ceramique-em/pack-100-perles/" data-reveal class="md:col-span-2 relative rounded-3xl overflow-hidden p-8 flex flex-col justify-between min-h-[300px] group transition-transform hover:scale-[1.01] bg-[#DDD8D0]">
          <span class="absolute right-3 top-1 font-display text-[100px] font-bold leading-none select-none opacity-[0.08] text-[#75592F]" aria-hidden="true">100</span>
          <div>
            <span class="inline-block bg-[#75592F] text-white text-xs font-semibold px-3 py-1 rounded-full mb-4">★ 4,94/5 (51 avis)</span>
            <h3 class="font-display text-2xl text-[#1A1A16] mb-2">Pack 100 Perles</h3>
            <p class="text-[#57534e] text-sm">Lave-vaisselle, bonbonne, machine à laver. Le format maison.</p>
          </div>
          <div>
            <p class="text-xs text-[#75592F] line-through">42,90€</p>
            <p class="font-display text-2xl text-[#166534] font-bold">29,90€</p>
          </div>
        </a>

        <!-- Pack Gourde — 3/5 cols -->
        <a href="/perles-ceramique-em/pack-gourde-ceramique-em/" data-reveal class="md:col-span-3 relative rounded-3xl overflow-hidden p-7 flex flex-col justify-between min-h-[220px] group transition-transform hover:scale-[1.01] bg-[#D0D8D4]">
          <span class="absolute right-4 bottom-3 font-display text-[55px] font-bold leading-none select-none opacity-[0.08] text-[#57534e]" aria-hidden="true">Gourde</span>
          <div>
            <span class="inline-block bg-[#166534] text-white text-xs font-semibold px-3 py-1 rounded-full mb-3">La formule complète</span>
            <h3 class="font-display text-2xl text-[#1A1A16] mb-1">Pack Gourde + 100 Perles</h3>
            <p class="text-[#57534e] text-sm">Gourde 500 ml en verre + 100 perles EM®. De quoi équiper aussi votre carafe.</p>
          </div>
          <div class="flex items-end justify-between">
            <div>
              <p class="text-xs text-[#75592F] line-through">72,80€</p>
              <p class="font-display text-2xl text-[#166534] font-bold">59,90€</p>
            </div>
            <span class="bg-[#166534] text-white px-5 py-2.5 rounded-full text-sm font-semibold group-hover:bg-[#0D4A25] transition-colors">Commander →</span>
          </div>
        </a>

        <!-- Gourde Écologique seule — 2/5 cols -->
        <a href="/perles-ceramique-em/gourde-ecologique/" data-reveal class="md:col-span-2 relative rounded-3xl overflow-hidden p-7 flex flex-col justify-between min-h-[220px] group transition-transform hover:scale-[1.01] bg-[#EDE4D3]">
          <span class="absolute right-3 top-0 font-display text-[70px] font-bold leading-none select-none opacity-[0.08] text-[#75592F]" aria-hidden="true">500</span>
          <div>
            <h3 class="font-display text-2xl text-[#1A1A16] mb-1">Gourde Écologique</h3>
            <p class="text-[#57534e] text-sm">500 ml en verre double paroi. Si vous avez déjà vos perles.</p>
          </div>
          <div>
            <p class="text-xs text-[#75592F] line-through">39,90€</p>
            <p class="font-display text-2xl text-[#166534] font-bold">29,90€</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════
       COMMENT ÇA MARCHE — bloc GEO
  ══════════════════════════════════ -->
  <section class="py-20 px-4 bg-white" aria-labelledby="how-it-works">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-xs tracking-[0.3em] uppercase text-[#75592F] mb-3">Mode d'emploi</p>
        <h2 id="how-it-works" class="font-display text-4xl text-[#1A1A16] mb-6">Comment ça marche ?</h2>
        <p class="text-[#57534e] leading-relaxed mb-8">
          Les Perles de Céramique EM® sont fabriquées à partir d'argile naturelle enrichie en
          Micro-organismes Efficaces (EM®). Ces micro-organismes bénéfiques améliorent la qualité
          de l'eau en réduisant le chlore, en adoucissant le goût et en limitant le tartre.
          Durée d'efficacité : 3 à 6 mois selon l'usage.
        </p>
        <a href="/comment-ca-marche/" class="inline-flex items-center gap-2 text-[#166534] font-semibold text-sm border-b border-[#166534] pb-0.5 hover:gap-4 transition-all">
          En savoir plus →
        </a>
        <a href="/utilisations/" class="inline-flex items-center gap-2 ml-6 text-[#166534] font-semibold text-sm border-b border-[#166534] pb-0.5 hover:gap-4 transition-all">
          Voir les 16 utilisations
        </a>
      </div>
      <div class="space-y-7">
        {steps.map(({ num, titre, texte }) => (
          <div class="flex gap-5">
            <span class="font-display text-3xl text-[#9C8358] font-bold leading-none flex-shrink-0 w-10" aria-hidden="true">{num}</span>
            <div>
              <h3 class="font-semibold text-[#1A1A16] mb-1">{titre}</h3>
              <p class="text-[#57534e] text-sm leading-relaxed">{texte}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════
       TESTIMONIALS
  ══════════════════════════════════ -->
  <section class="py-20 px-4 bg-[#F5F0E8]" aria-labelledby="avis-titre">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-xs tracking-[0.3em] uppercase text-[#75592F] mb-3">Ce qu'ils en disent</p>
        <h2 id="avis-titre" class="font-display text-4xl text-[#1A1A16]">{SITE.totalReviews} clients satisfaits</h2>
        <p class="text-[#166534] text-xl mt-2" aria-label={`Note globale ${SITE.globalRating} sur 5`}>★★★★★ <span class="text-[#57534e] text-base">{SITE.globalRating.toString().replace('.', ',')} / 5</span></p>
        <p class="text-xs text-[#57534e] mt-1">Extraits mot pour mot d'avis vérifiés publiés sur nos fiches produit.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {testimonials.map(({ name, pack, texte }) => (
          <div class="bg-white rounded-2xl p-6" data-reveal>
            <p class="text-[#166534] mb-3" aria-label="Note 5 étoiles">★★★★★</p>
            <p class="text-[#57534e] text-sm leading-relaxed mb-4 italic">« {texte} »</p>
            <div class="flex items-center justify-between">
              <span class="font-semibold text-[#1A1A16] text-sm">{name}</span>
              <span class="text-xs text-[#75592F] bg-[#F5F0E8] px-2 py-1 rounded-full">{pack}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════
       GUIDES — blog / ressources
  ══════════════════════════════════ -->
  <section class="py-20 px-4 bg-white" aria-labelledby="guides-titre">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-wrap items-end justify-between gap-6 mb-12">
        <div>
          <p class="text-xs tracking-[0.3em] uppercase text-[#75592F] mb-3">Nos guides</p>
          <h2 id="guides-titre" class="font-display text-4xl text-[#1A1A16]">Tout savoir sur les perles de céramique</h2>
        </div>
        <a href="/blog/" class="inline-flex items-center gap-2 text-[#166534] font-semibold text-sm border-b border-[#166534] pb-0.5 hover:gap-4 transition-all">
          Voir tous les guides →
        </a>
      </div>
      <div class="grid md:grid-cols-2 gap-5">
        {guides.filter((g) => g.category !== 'Achat').map((guide) => (
          <article class="rounded-2xl border border-[#EDE8E0] bg-[#FDFBF7] p-6" data-reveal>
            <p class="text-xs tracking-widest uppercase text-[#75592F] mb-3">{guide.category}</p>
            <h3 class="font-display text-2xl text-[#1A1A16] mb-3">
              <a href={guide.href} class="hover:text-[#166534] transition-colors">{guide.title}</a>
            </h3>
            <p class="text-[#57534e] text-sm leading-relaxed mb-5">{guide.description}</p>
            <a href={guide.href} class="inline-flex text-sm font-semibold text-[#166534] hover:underline">
              Lire le guide
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════
       MISSION
  ══════════════════════════════════ -->
  <section class="py-20 px-4 bg-[#0D2818] text-white">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs tracking-[0.3em] uppercase text-[#A8C4A0] mb-4">Notre mission</p>
      <h2 class="font-display text-4xl lg:text-5xl mb-6 leading-tight">
        Moins de bouteilles plastique,<br />
        <span class="text-[#A8C4A0]">une eau meilleure</span>
      </h2>
      <p class="text-[#B8CCB4] leading-relaxed mb-10 text-lg">
        Un foyer qui passe aux perles cesse d'acheter de l'eau en bouteille :
        moins de plastique jeté, moins de packs à porter, et une eau du robinet
        enfin agréable à boire. C'est exactement pour ça que nous existons.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/perles-ceramique-em/" class="bg-[#A8C4A0] text-[#0D2818] px-8 py-3.5 rounded-full font-semibold hover:bg-white transition-colors">
          Commander maintenant
        </a>
        <a href="/a-propos/" class="border border-[#A8C4A0] text-[#A8C4A0] px-8 py-3.5 rounded-full font-semibold hover:bg-[#A8C4A0] hover:text-[#0D2818] transition-colors">
          Notre histoire →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
